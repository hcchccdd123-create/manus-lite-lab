APP_ENV=prod
HOST=0.0.0.0
PORT=8000
DB_URL=sqlite+aiosqlite:///./data/chat.db
DEFAULT_PROVIDER=glm
DEFAULT_MODEL_OLLAMA=qwen3.5:0.8b
OLLAMA_BASE_URL=http://127.0.0.1:11434
GLM_API_KEY=
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
GLM_MODEL=glm-4.7
CODEX_API_KEY=
CODEX_BASE_URL=
CODEX_MODEL=gpt-4.1-mini
MEMORY_WINDOW_SIZE=12
SUMMARY_TRIGGER_MESSAGES=20
GENERATION_TOP_P=0.9
GENERATION_REPEAT_PENALTY=1.12
ENABLE_THINKING_LOOP_GUARD=true
THINKING_LOOP_MAX_CHARS=12000
THINKING_LOOP_REPEAT_WINDOW=14
THINKING_LOOP_REPEAT_THRESHOLD=4
ENABLE_PROVIDER_FALLBACK=false
