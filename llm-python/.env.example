APP_ENV=dev
HOST=0.0.0.0
PORT=8000
APP_TIMEZONE=Asia/Shanghai
DB_URL=postgresql+asyncpg://manus:your_password@localhost:5432/manus_rag_demo
RAG_ENABLED=false
RAG_DOCS_DIR=./docs
RAG_TOP_K=4
RAG_CHUNK_SIZE=800
RAG_CHUNK_OVERLAP=120
RAG_SIMILARITY_THRESHOLD=0.45
DEFAULT_PROVIDER=glm
DEFAULT_MODEL_OLLAMA=qwen3.5:0.8b
OLLAMA_BASE_URL=http://127.0.0.1:11434
GLM_API_KEY=
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
GLM_MODEL=glm-4.7
GLM_EMBEDDING_MODEL=embedding-3
CODEX_API_KEY=
CODEX_BASE_URL=
CODEX_MODEL=gpt-4.1-mini
CHROMA_HOST=127.0.0.1
CHROMA_PORT=8001
CHROMA_COLLECTION=rag_demo
MEMORY_WINDOW_SIZE=12
SUMMARY_TRIGGER_MESSAGES=20
GENERATION_TOP_P=0.9
GENERATION_REPEAT_PENALTY=1.12
ENABLE_THINKING_LOOP_GUARD=true
THINKING_LOOP_MAX_CHARS=12000
THINKING_LOOP_REPEAT_WINDOW=14
THINKING_LOOP_REPEAT_THRESHOLD=4
THINKING_LOOP_MAX_SECONDS=90
ENABLE_PROVIDER_FALLBACK=false
