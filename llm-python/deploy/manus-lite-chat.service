[Unit]
Description=Manus Lite Chat Backend
After=network.target

[Service]
Type=simple
WorkingDirectory=/opt/manus-lite-chat/app
EnvironmentFile=/opt/manus-lite-chat/app/.env
ExecStart=/opt/manus-lite-chat/venv/bin/uvicorn app.main:app --host 0.0.0.0 --port 8000 --workers 2
Restart=always
RestartSec=3
User=root
Group=root

[Install]
WantedBy=multi-user.target
